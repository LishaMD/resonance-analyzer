# Resonance Analyzer — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub. It is already in .gitignore.

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Flask Extraction Service ─────────────────────────────────────────────────
# Update this every session when you restart ngrok
NGROK_URL=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=   # Use the service_role key, not the anon key

# ── Airtable ─────────────────────────────────────────────────────────────────
# Token: airtable.com → Account → Developer Hub → Personal access tokens
# Base ID: open your base in browser → URL contains /appXXXXXXXXXXXXXX/
AIRTABLE_TOKEN=pat...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# These default to the names below — only set if your table names differ
# AIRTABLE_EVIDENCE_TABLE=Evidence Items
# AIRTABLE_PATTERNS_TABLE=Cross-Force Patterns
